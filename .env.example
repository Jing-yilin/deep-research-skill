# ============================================================================
# deep-research skill — environment variables
# Copy to `.env` (or export in your shell / ~/.zshrc) and fill in the values.
# Only the keys for the workers you actually use are required.
# ============================================================================

# --- Twitter / X  (Worker C, and person-research social lookup) -------------
# Provider: twitterapi.io   Get key: https://twitterapi.io  (dashboard → API Key)
TWITTERAPI_API_KEY=

# --- LinkedIn  (Worker F, and person-research profiles) ---------------------
# Provider: HarvestAPI      Get key: https://harvest-api.com  (sign up → API key)
HARVESTAPI_API_KEY=

# --- Reddit enhanced search + ScrapeCreators skill --------------------------
# Basic Reddit search/read works WITHOUT this key (public JSON API).
# Needed only for --sort comment_count / best and the scrapecreators-api skill.
# Provider: ScrapeCreators  Get key: https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# --- WeChat Official Accounts  (Worker G — Chinese-market topics) -----------
# These point at a self-hosted WeChat-article exporter backend (see README).
# There is no public vendor; you deploy the backend yourself and the key is
# tied to a logged-in WeChat MP session.
WECHAT_API_BASE_URL=
WECHAT_API_KEY=

# --- YouTube  (optional — person-research media lookups only) ---------------
# YOUTUBE_API_KEY  Provider: Google Cloud Console → YouTube Data API v3
# TRANSCRIPT_API_KEY (optional) Provider: https://www.transcriptapi.com
YOUTUBE_API_KEY=
TRANSCRIPT_API_KEY=

# --- Optional enrichment (person-research deep founder/exec lookups) --------
# HUNTER_API_KEY        https://hunter.io        (verified email finder)
# PEOPLEDATALABS_API_KEY https://peopledatalabs.com (social profiles + career)
HUNTER_API_KEY=
PEOPLEDATALABS_API_KEY=

# --- Optional: Composio (only for LinkedIn/Reddit/Twitter WRITE ops) --------
# Not used by deep-research read flows. https://composio.dev
COMPOSIO_API_KEY=
